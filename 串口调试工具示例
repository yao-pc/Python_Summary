# serial_debugger.py
import sys
import serial
import serial.tools.list_ports
from PyQt5.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout,
    QHBoxLayout, QLabel, QComboBox, QPushButton,
    QTextEdit, QSpacerItem, QSizePolicy
)
from PyQt5.QtCore import QTimer, Qt
from PyQt5.QtGui import QFont
import pyqtgraph as pg
import binascii


class SerialDebugger(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("串口调试助手 - Python + PyQt")
        self.resize(1000, 600)

        # 串口对象
        self.ser = None

        # 波形数据
        self.data_buffer = []
        self.max_points = 500  # 最多显示 500 个点

        # 创建 UI
        self.init_ui()

        # 定时器：用于刷新波形和接收数据
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_display)
        self.timer.start(100)  # 每 100ms 刷新一次

    def init_ui(self):
        # 主窗口布局
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        layout = QVBoxLayout(central_widget)
        layout.setSpacing(10)
        layout.setContentsMargins(10, 10, 10, 10)

        # === 顶部控制区 ===
        control_layout = QHBoxLayout()

        # 串口选择
        control_layout.addWidget(QLabel("串口:"))
        self.com_combo = QComboBox()
        self.com_combo.setEditable(True)
        self.com_combo.setFixedWidth(120)
        self.update_com_ports()
        control_layout.addWidget(self.com_combo)

        # 波特率选择
        control_layout.addWidget(QLabel("波特率:"))
        self.baud_combo = QComboBox()
        self.baud_combo.addItems(["9600", "115200", "57600", "38400"])
        self.baud_combo.setCurrentText("115200")
        self.baud_combo.setFixedWidth(100)
        control_layout.addWidget(self.baud_combo)

        # 打开/关闭按钮
        self.open_btn = QPushButton("打开串口")
        self.open_btn.setFixedWidth(100)
        self.open_btn.clicked.connect(self.toggle_serial)
        control_layout.addWidget(self.open_btn)

        # 添加控制区到主布局
        layout.addLayout(control_layout)

        # === 中间数据区 ===
        data_layout = QHBoxLayout()

        # 接收区（文本显示）
        recv_group = QWidget()
        recv_layout = QVBoxLayout(recv_group)
        recv_layout.setContentsMargins(5, 5, 5, 5)
        recv_layout.addWidget(QLabel("接收数据:"))
        self.recv_text = QTextEdit()
        self.recv_text.setReadOnly(True)
        self.recv_text.setFont(QFont("Consolas", 10))
        recv_layout.addWidget(self.recv_text)
        data_layout.addWidget(recv_group, 1)

        # 发送区（输入框 + 发送按钮）
        send_group = QWidget()
        send_layout = QVBoxLayout(send_group)
        send_layout.setContentsMargins(5, 5, 5, 5)
        send_layout.addWidget(QLabel("发送数据:"))
        self.send_input = QTextEdit()
        self.send_input.setFixedHeight(60)
        self.send_input.setFont(QFont("Consolas", 10))
        send_layout.addWidget(self.send_input)

        send_btn_layout = QHBoxLayout()
        self.send_hex = QPushButton("HEX发送")
        self.send_hex.setFixedWidth(80)
        self.send_hex.clicked.connect(self.send_hex_data)
        send_btn_layout.addWidget(self.send_hex)

        self.send_text = QPushButton("文本发送")
        self.send_text.setFixedWidth(80)
        self.send_text.clicked.connect(self.send_text_data)
        send_btn_layout.addWidget(self.send_text)

        send_layout.addLayout(send_btn_layout)
        data_layout.addWidget(send_group, 1)

        layout.addLayout(data_layout)

        # === 底部波形区 ===
        waveform_layout = QHBoxLayout()

        waveform_layout.addWidget(QLabel("波形显示:"))
        self.plot_widget = pg.PlotWidget()
        self.plot_widget.setLabel('bottom', '时间')
        self.plot_widget.setLabel('left', '电压/数值')
        self.plot_widget.setBackground('w')
        self.plot_widget.showGrid(x=True, y=True)
        self.plot_widget.setLimits(xMin=0, xMax=100, yMin=-1, yMax=1)
        waveform_layout.addWidget(self.plot_widget)

        layout.addLayout(waveform_layout)

    def update_com_ports(self):
        """刷新串口列表"""
        self.com_combo.clear()
        ports = serial.tools.list_ports.comports()
        for port in ports:
            self.com_combo.addItem(port.device)

    def toggle_serial(self):
        """打开或关闭串口"""
        if self.ser is None or not self.ser.is_open:
            port = self.com_combo.currentText()
            baud = int(self.baud_combo.currentText())
            try:
                self.ser = serial.Serial(port, baud, timeout=1)
                self.open_btn.setText("关闭串口")
                self.recv_text.append(f"[+] 串口 {port} 打开成功，波特率：{baud}")
            except Exception as e:
                self.recv_text.append(f"[-] 打开失败：{e}")
        else:
            self.ser.close()
            self.ser = None
            self.open_btn.setText("打开串口")
            self.recv_text.append(f"[-] 串口已关闭")

    def send_hex_data(self):
        """发送十六进制数据"""
        data = self.send_input.toPlainText().strip()
        if not data:
            return
        try:
            # 去掉空格，按空格或逗号分隔
            data = data.replace(',', ' ').replace('\t', ' ')
            bytes_data = bytes.fromhex(data)
            self.ser.write(bytes_data)
            # 显示发送的数据（十六进制）
            hex_str = ' '.join(f'{b:02X}' for b in bytes_data)
            self.recv_text.append(f"[SEND] {hex_str}")
        except Exception as e:
            self.recv_text.append(f"[-] HEX发送失败：{e}")

    def send_text_data(self):
        """发送文本数据"""
        text = self.send_input.toPlainText().strip()
        if not text:
            return
        try:
            self.ser.write(text.encode('utf-8'))
            self.recv_text.append(f"[SEND] {text}")
        except Exception as e:
            self.recv_text.append(f"[-] 文本发送失败：{e}")

    def update_display(self):
        """定时更新数据接收和波形"""
        if self.ser is None or not self.ser.is_open:
            return

        try:
            if self.ser.in_waiting > 0:
                raw_data = self.ser.read(self.ser.in_waiting)
                # 解码为文本（UTF-8）
                try:
                    text_data = raw_data.decode('utf-8')
                    self.recv_text.append(f"[RECV] {text_data}")
                except:
                    pass  # 解码失败，可能是二进制数据

                # 转为数值数组用于波形显示
                # 这里简单按字节转为 0~255 的数值
                values = [int(b) for b in raw_data]
                self.data_buffer.extend(values)

                # 限制缓冲区长度
                if len(self.data_buffer) > self.max_points:
                    self.data_buffer = self.data_buffer[-self.max_points:]

                # 更新波形
                self.plot_waveform()
        except Exception as e:
            self.recv_text.append(f"[-] 读取串口失败：{e}")

    def plot_waveform(self):
        """绘制波形"""
        if not self.data_buffer:
            return

        # 使用 pyqtgraph 绘制
        self.plot_widget.clear()
        x = list(range(len(self.data_buffer)))
        y = self.data_buffer
        self.plot_widget.plot(x, y, pen='b', width=1)


# 启动应用
if __name__ == '__main__':
    app = QApplication(sys.argv)
    window = SerialDebugger()
    window.show()
    sys.exit(app.exec_())
